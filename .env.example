# Copy to .env for local development. All values shown are the defaults
# hard-coded in the source, so you only need to override what changes.

# --- Infrastructure ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bim_mep
REDIS_URL=redis://localhost:6379

# --- Ingestion Gateway ---
# MQTT broker port exposed by the gateway
MQTT_PORT=1883

# --- Signal Simulator ---
INGESTION_GATEWAY_URL=http://localhost:3100
# How many signals to buffer before flushing a batch
INGEST_BATCH_SIZE=200
# Max time (ms) to wait before flushing a partial batch
INGEST_FLUSH_INTERVAL_MS=250

# --- Stream Processor ---
# Time (ms) an anomaly must persist before firing
ANOMALY_PENDING_MS=5000
